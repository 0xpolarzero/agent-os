    "@rivet-dev/agent-os-findutils": "0.0.260331072558",
    "@rivet-dev/agent-os-diffutils": "0.0.260331072558",
    "@rivet-dev/agent-os-tar": "0.0.260331072558",
    "@rivet-dev/agent-os-gzip": "0.0.260331072558"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.9.2"
  }
